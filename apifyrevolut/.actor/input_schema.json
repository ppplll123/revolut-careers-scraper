{
    "title": "Revolut Careers Scraper Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "city": {
            "title": "City Filter",
            "type": "string",
            "description": "City filter for Revolut careers (URL-encoded)",
            "default": "UAE+-+Remote",
            "editor": "textfield"
        },
        "teams": {
            "title": "Teams to Scrape",
            "type": "array",
            "description": "List of team names to scrape (in preference order). Leave empty for all UAE teams.",
            "default": [
                "Executive",
                "Risk, Compliance & Audit",
                "Product & Design",
                "Credit",
                "Finance",
                "Legal",
                "Marketing & Comms",
                "Operations",
                "Business Development",
                "Support & FinCrime"
            ],
            "editor": "stringList"
        },
        "skipPatterns": {
            "title": "Skip Title Patterns",
            "type": "array",
            "description": "Regex patterns for job titles to skip (case-insensitive)",
            "default": [
                "\\b(intern|internship)\\b",
                "\\b(student|graduate)\\b",
                "\\b(junior|jr\\.?)\\b",
                "\\b(entry.level)\\b",
                "\\b(apprentice)\\b"
            ],
            "editor": "stringList"
        },
        "maxShowMoreClicks": {
            "title": "Max 'Show More' Clicks",
            "type": "integer",
            "description": "Maximum number of times to click 'Show more' per team page",
            "default": 20,
            "minimum": 1,
            "maximum": 50
        }
    },
    "required": []
}
